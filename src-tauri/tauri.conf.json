{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VolleyScoutPro",
  "version": "0.1.3",
  "identifier": "agency.blackfoxmedia.volleyscoutpro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VolleyScoutPro",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "BlackFox Media",
    "copyright": "© 2025 BlackFox Media. Tutti i diritti riservati.",
    "category": "Sports",
    "shortDescription": "Software professionale di scouting pallavolo",
    "longDescription": "VolleyScoutPro è il software professionale per l'analisi e lo scouting delle partite di pallavolo. Registra eventi in tempo reale, analizza le statistiche e condividi i dati con il tuo staff tecnico.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "it-IT"
      },
      "nsis": {
        "languages": ["Italian"],
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
